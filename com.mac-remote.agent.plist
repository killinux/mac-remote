<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mac-remote.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/mac-remote/mac.sh</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/usr/local/bin/mac-remote</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/mac-remote.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/mac-remote.log</string>
</dict>
</plist>
